{
  "name": "test-app-vite",
  "version": "0.0.0",
  "private": true,
  "description": "Small description for test-app-vite goes here",
  "repository": "",
  "license": "MIT",
  "author": "",
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "vite build",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" --prefixColors auto && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "ember-tsc --noEmit",
    "start": "vite",
    "test": "vite build --mode development && ember test --path dist",
    "_syncPnpm": "pnpm sync-dependencies-meta-injected",
    "test:ember": "pnpm _syncPnpm && NODE_ENV=development vite build --mode development && ember test --path dist"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/eslint-parser": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/plugin-transform-typescript": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@ember/app-tsconfig": "^2.0.0",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.3",
    "@ember/test-waiters": "^4.1.2",
    "@embroider/compat": "^4.1.20",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.6.1",
    "@embroider/macros": "^1.20.4",
    "@embroider/router": "^3.0.6",
    "@embroider/vite": "^1.7.7",
    "@eslint/js": "^9.39.4",
    "@glimmer/component": "^2.1.1",
    "@glint/ember-tsc": "^1.8.1",
    "@glint/template": "^1.7.8",
    "@glint/tsserver-plugin": "^2.5.7",
    "@rollup/plugin-babel": "^7.1.0",
    "@types/qunit": "^2.19.14",
    "@types/rsvp": "^4.0.9",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "concurrently": "^9.2.3",
    "decorator-transforms": "^2.3.2",
    "ember-cli": "~7.1.0",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-deprecation-workflow": "^4.0.1",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.1.0",
    "ember-resolver": "^13.2.0",
    "ember-source": "7.3.0-alpha.4",
    "ember-template-lint": "^7.9.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.5",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-qunit": "^8.2.6",
    "globals": "^16.5.0",
    "prettier": "^3.8.4",
    "prettier-plugin-ember-template-tag": "^2.1.6",
    "qunit": "^2.26.0",
    "qunit-dom": "^3.5.1",
    "testem": "^3.20.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "pnpm-sync-dependencies-meta-injected": "^0.0.15"
  },
  "engines": {
    "node": ">= 20.19.0"
  },
  "ember": {
    "edition": "octane"
  },
  "dependencies": {
    "ember-resources": "workspace:*"
  },
  "dependenciesMeta": {
    "ember-resources": {
      "injected": true
    }
  }
}
