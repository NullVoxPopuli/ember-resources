    "lint:js": "eslint . --cache",
    "lint:prettier": "prettier --check '**/*.{js,ts}'",
    "lint:prettier:fix": "prettier --write '**/*.{js,ts}'",
    "lint:js:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@nullvoxpopuli/eslint-configs": "^6.0.0",
    "@tsconfig/node22": "^22.0.0",
    "@tsconfig/strictest": "^2.0.5",
    "@types/node": "^22.5.4",
    "@types/semver": "^7.5.8",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "typescript": "~5.5.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "find-up": "^7.0.0",
    "globby": "^14.0.0",
    "semver": "^7.6.3"
  }
