{
  "name": "ember-resources-codemod",
  "version": "0.1.4",
  "bin": "./bin.mjs",
  "type": "module",
  "repository": "https://github.com/NullVoxPopuli/ember-resources",
  "files": [
    "bin.mjs",
    "src"
  ],
  "engines": {
    "node": "^22.16.0 || >= 24"
  },
  "scripts": {
    "lint": "concurrently 'npm:lint:*(!fix)' --names 'lint:'",
